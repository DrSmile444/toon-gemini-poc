{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "paths": {
      "@data/*": [
        "./src/data/*"
      ],
      "@poc/*": [
        "./src/poc/*"
      ],
      "@prompt/*": [
        "./src/prompt/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
